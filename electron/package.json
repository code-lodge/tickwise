{
  "name": "tickwise-desktop",
  "productName": "Tickwise",
  "version": "1.0.0",
  "description": "Tickwise — privacy-first automatic time tracking for freelancers",
  "homepage": "https://tickwise.app",
  "main": "main.js",
  "author": {
    "name": "Code Lodge",
    "email": "hello@code-lodge.io"
  },
  "license": "GPL-3.0",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win nsis portable --x64",
    "build:mac": "electron-builder --mac dmg --universal",
    "build:linux": "electron-builder --linux AppImage --x64",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "io.code-lodge.tickwise",
    "productName": "Tickwise",
    "copyright": "© 2026 Code Lodge",
    "asar": true,
    "directories": {
      "output": "../dist-electron",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "loading.html",
      "build/icon.*"
    ],
    "extraResources": [
      {
        "from": "../dist/Tickwise",
        "to": "tickwise-backend",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.ico",
      "artifactName": "Tickwise-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Tickwise"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extendInfo": {
        "LSUIElement": false,
        "NSAccessibilityUsageDescription": "Tickwise reads window titles to classify your activity.",
        "NSAppleEventsUsageDescription": "Tickwise observes the active application."
      }
    },
    "dmg": {
      "artifactName": "Tickwise-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Office",
      "artifactName": "Tickwise-${version}.${ext}"
    }
  }
}
